---
import Base from "@layouts/Base.astro";
import Hero from "@components/sections/Hero.astro";
import SignalLayer from "@components/sections/SignalLayer.astro";
import Diagnostico from "@components/sections/Diagnostico.astro";
import Operacao from "@components/sections/Operacao.astro";
import Roadmap from "@components/sections/Roadmap.astro";
import Cta from "@components/sections/Cta.astro";
import { cliente } from "@data/proposta";
---

<Base titulo={`${cliente.nome} — Continuidade de Dados`}>
  <div class="dashboard">
    <aside class="sidebar glass">
      <nav class="menu" id="presentation-menu">
        <button class="menu-item active" data-target="visao-geral">
          <span class="num mono">00</span>
          Visão Geral
        </button>
        <button class="menu-item" data-target="camada-sobrevive">
          <span class="num mono">01</span>
          A Camada que Sobrevive
        </button>
        <button class="menu-item" data-target="diagnostico">
          <span class="num mono">02</span>
          Diagnóstico Técnico
        </button>
        <button class="menu-item" data-target="operacao" data-theme="light">
          <span class="num mono">03</span>
          Plano de Operação
        </button>
        <button class="menu-item" data-target="roadmap">
          <span class="num mono">04</span>
          Roadmap
        </button>
      </nav>
    </aside>

    <div class="stage theme-light">
      <div id="visao-geral" class="tab-content active">
        <Hero />
      </div>
      <div id="camada-sobrevive" class="tab-content">
        <SignalLayer />
      </div>
      <div id="diagnostico" class="tab-content">
        <Diagnostico />
      </div>
      <div id="operacao" class="tab-content">
        <Operacao />
      </div>
      <div id="roadmap" class="tab-content">
        <Roadmap />
        <Cta />
      </div>
    </div>
  </div>

  <script>
    // Configura a transição das abas
    function initTabs() {
      const buttons = document.querySelectorAll('.menu-item');
      const tabs = document.querySelectorAll('.tab-content');

      buttons.forEach(button => {
        button.addEventListener('click', () => {
          buttons.forEach(b => b.classList.remove('active'));
          tabs.forEach(t => t.classList.remove('active'));

          button.classList.add('active');
          const targetId = button.getAttribute('data-target');

          if (targetId) {
            const targetTab = document.getElementById(targetId);
            if (targetTab) {
              targetTab.classList.add('active');
            }
          }
        });
      });
    }

    function printEasterEgg() {
      // Evita imprimir multiplas vezes durante navegacao
      if ((window as any).__easterEggPrinted) return;
      (window as any).__easterEggPrinted = true;

      const titleStyle = "color: #c80c99; font-weight: bold; font-size: 16px; font-family: monospace;";
      const subStyle = "color: #6ba1ff; font-weight: bold; font-size: 14px; font-family: monospace;";
      const bodyStyle = "color: #E1E8E1; font-size: 12px; font-family: monospace; line-height: 1.5;";

      console.log("%c// NEØ MELLØ", titleStyle);
      console.log("%c> SINAL ESTABELECIDO: DIAGNÓSTICO DE CONTINUIDADE", subStyle);
      console.log(
        "%c\n" +
        "STATUS DA OPERAÇÃO : ATIVA\n" +
        "ALVO               : usemariamaral.com.br\n" +
        "OBJETIVO           : Blindagem da infraestrutura de aquisição\n\n" +
        "A inteligência não reseta. O histórico não se perde.\n" +
        "Apresentação pronta para iniciar.",
        bodyStyle
      );
    }

    // Como usamos ViewTransitions, inicializamos no carregamento
    // e escutamos o evento astro:page-load para reinicializar
    document.addEventListener('astro:page-load', () => {
      initTabs();
      printEasterEgg();
    });
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initTabs();
      printEasterEgg();
    }
  </script>
</Base>
