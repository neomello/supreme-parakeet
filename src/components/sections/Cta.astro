---
import { cta } from "@data/proposta";
---

<section class="cta fade-in">
  <div class="cta-box glass">
    <div class="content">
      <h2>{cta.titulo}</h2>
      <p>{cta.descricao}</p>
    </div>
    <button class="btn-primary mono" onclick="alert('Iniciando handshake operacional...'); document.getElementById('roadmap').classList.remove('active'); document.getElementById('visao-geral').classList.add('active'); document.querySelectorAll('.menu-item').forEach(b => b.classList.remove('active')); document.querySelector('.menu-item[data-target=\\'visao-geral\\']').classList.add('active');">
      {">"} APROVAR PROPOSTA
    </button>
  </div>
</section>

<style>
  .cta-box {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    border-radius: 16px;
    padding: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 32px;
  }
  
  @media (max-width: 720px) {
    .cta-box {
      flex-direction: column;
      align-items: flex-start;
      padding: 32px 24px;
    }
  }
  
  h2 {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 8px;
  }
  
  p {
    font-size: var(--fs-body);
    color: var(--text-muted);
    line-height: 1.5;
  }
  
  .btn-primary {
    background: var(--text-main);
    color: var(--bg-stage);
    border: none;
    padding: 16px 32px;
    border-radius: 8px;
    font-size: var(--fs-small);
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    background: var(--signal);
    color: #fff;
  }
</style>
