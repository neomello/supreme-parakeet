          <defs>
            <clipPath id="clip0_634_49">
              <rect width="174" height="60" fill="white"/>
            </clipPath>
          </defs>
        </svg>
      </div>
      <p class="eyebrow">▸ {tese.eyebrow}</p>
      <h1>
        {antes}<em class="text-gradient">{tese.destaque}</em>{depois}
      </h1>
      <p class="lede">{tese.lede}</p>
    </div>

    <aside class="signature-card glass mono" style="animation-delay: 0.2s">
      <div class="line"><b>{autor.nome}</b></div>
      <div class="line">{autor.papel}</div>
      <div class="sep"></div>
      <div class="line">cliente: {cliente.nome}</div>
      <div class="line">{cliente.dominio}</div>
      <div class="line">{autor.horizonte}</div>
    </aside>
  </div>

  <div class="leitura-inicial fade-in" style="animation-delay: 0.4s">
    <div class="window-header">
      <div class="window-buttons">
        <span class="dot close"></span>
        <span class="dot minimize"></span>
        <span class="dot zoom"></span>
      </div>
      <span class="window-title">{leituraInicial.titulo}</span>
    </div>
    <div class="window-body">
      <div class="leitura-grid">
        {leituraInicial.pontos.map(p => (
          <div class="leitura-row">
            <span class="label">{p.label}</span>
            <span class="value">{p.valor}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</header>

<style>
  .hero-container {
    display: flex;
    flex-direction: column;
    gap: 48px;
    margin-bottom: var(--section);
  }
  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
  }
  .brand-logo {
    margin-bottom: 24px;
    color: var(--text-main);
  }
  .brand-logo svg {
    display: block;
    transition: color 0.3s ease;
  }
  .lead {
    max-width: 620px;
  }
  .eyebrow {
    margin-bottom: 20px;
    color: var(--accent);
    font-weight: 600;
  }
  h1 {
    font-size: var(--fs-display);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.015em;
    color: var(--text-main);
  }
  h1 em.text-gradient {
    font-style: normal;
    color: transparent;
    background: var(--text-gradient);
    -webkit-background-clip: text;
    background-clip: text;
  }
  .lede {
    margin-top: 16px;
    color: var(--text-muted);
    font-size: var(--fs-body);
    max-width: 480px;
    white-space: pre-line;
    line-height: 1.6;
  }
  
  /* Signature Card */
  .signature-card {
    flex-shrink: 0;
    font-size: var(--fs-micro);
    color: var(--text-faint);
    min-width: 240px;
    padding: 24px;
    border-radius: 12px;
    text-align: left;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .signature-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--glass-shadow);
  }
  .signature-card b {
    color: var(--text-main);
    font-weight: 600;
  }
  .signature-card .line {
    line-height: 1.9;
  }
  .sep {
    height: 1px;
    background: var(--rule);
    margin: 12px 0;
  }

  /* Glass Card & General Styles */
  .glass {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
  }

  /* macOS Window Style */
  .leitura-inicial {
    background: #FFFFFF;
    border: 1px solid #D1D1D6;
    border-radius: 12px;
    box-shadow: 
      0 10px 30px rgba(0, 0, 0, 0.05),
      0 1px 3px rgba(0, 0, 0, 0.02);
    text-align: left;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .window-header {
    height: 38px;
    background: #F2F2F7;
    border-bottom: 1px solid #E5E5EA;
    display: flex;
    align-items: center;
    padding: 0 16px;
    position: relative;
  }
  .window-buttons {
    display: flex;
    gap: 8px;
  }
  .window-buttons .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }
  .window-buttons .dot.close { background: #FF5F56; }
  .window-buttons .dot.minimize { background: #FFBD2E; }
  .window-buttons .dot.zoom { background: #27C93F; }
  
  .window-title {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "SF Pro", "Segoe UI", sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #3A3A3C;
  }
  .window-body {
    padding: 28px;
  }
  .leitura-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .leitura-row {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 20px;
    align-items: baseline;
    border-bottom: 1px solid #F2F2F7;
    padding-bottom: 12px;
  }
  .leitura-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }
  .leitura-row .label {
    color: #8E8E93; /* macOS System Grey */
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .leitura-row .value {
    color: #1C1C1E;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1.4;
  }

  @media (max-width: 820px) {
    .hero-top {
      flex-direction: column;
    }
    .signature-card {
      min-width: 100%;
    }
    .leitura-row {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
