---
import { autor, cliente, tese } from "@data/proposta";
import logoMariAmaral from "../../assets/logo-mari-amaral.svg";

// Quebra a tese em torno da palavra de destaque para
// aplicar enfase sem markup hardcoded no conteudo.
const [antes, depois] = tese.titulo.split(tese.destaque);
---

<header class="hero fade-in">
  <div class="lead">
    <div class="brand-logo" aria-hidden="true">
      <img src={logoMariAmaral.src} alt="Mari Amaral Logo" width="174" height="60" />
    </div>
    <p class="eyebrow">▸ {tese.eyebrow}</p>
    <h1>
      {antes}<em class="text-gradient">{tese.destaque}</em>{depois}
    </h1>
    <p class="lede">{tese.lede}</p>
  </div>

  <aside class="card glass mono fade-in" style="animation-delay: 0.2s">
    <div class="line"><b>{autor.nome}</b></div>
    <div class="line">{autor.papel}</div>
    <div class="sep"></div>
    <div class="line">cliente: {cliente.nome}</div>
    <div class="line">{cliente.dominio}</div>
    <div class="line">{autor.horizonte}</div>
  </aside>
</header>

<style>
  .hero {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 40px;
    margin-bottom: var(--section);
  }
  .brand-logo {
    margin-bottom: 24px;
  }
  .brand-logo img {
    filter: brightness(0);
  }
  .lead {
    max-width: 620px;
  }
  .eyebrow {
    margin-bottom: 20px;
    color: var(--accent);
    font-weight: 600;
  }
  h1 {
    font-size: var(--fs-display);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.015em;
  }
  h1 em.text-gradient {
    font-style: normal;
    color: transparent;
    background: var(--text-gradient);
    -webkit-background-clip: text;
    background-clip: text;
  }
  .lede {
    margin-top: 16px;
    color: var(--text-muted);
    font-size: var(--fs-body);
    max-width: 480px;
    white-space: pre-line;
  }
  
  /* Glass Card */
  .glass {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    border-radius: 16px;
    padding: 24px;
  }
  
  .card {
    flex-shrink: 0;
    font-size: var(--fs-micro);
    color: var(--text-faint);
    min-width: 240px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px 0 rgba(0, 0, 0, 0.6);
  }
  .card b {
    color: var(--text-main);
    font-weight: 600;
  }
  .line {
    line-height: 1.9;
  }
  .sep {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 12px 0;
  }
  @media (max-width: 720px) {
    .hero {
      flex-direction: column;
      gap: 32px;
    }
    .card {
      align-self: stretch;
    }
  }
</style>
