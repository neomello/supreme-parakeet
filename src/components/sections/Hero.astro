---
import { autor, cliente, tese, leituraInicial } from "@data/proposta";

// Quebra a tese em torno da palavra de destaque para
// aplicar enfase sem markup hardcoded no conteudo.
const [antes, depois] = tese.titulo.split(tese.destaque);
---

