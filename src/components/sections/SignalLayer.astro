---
import { diagrama as d, teseOperacao } from "@data/proposta";
---

<section class="sig fade-in">
  <div class="intro">
    <p class="eyebrow">▸ {teseOperacao.eyebrow}</p>
    <h2>{teseOperacao.titulo}</h2>
    <p class="lede">{teseOperacao.lede}</p>
    <div class="tese-box glass">
      <span class="mono tese-label">Tese</span>
      <p>{teseOperacao.tesePrincipal}</p>
    </div>
  </div>

  <p class="eyebrow-diagram">// {d.label}</p>

  <div class="grid glass">
    <!-- COLUNA 1: fontes de trafego -->
    <div class="col sources">
      {d.fontes.map((f) => (
        <div class="src mono">
          <span class="caret">▸</span>{f}
        </div>
      ))}
    </div>

    <!-- conector -->
    <div class="conn" aria-hidden="true">
      <span class="mono glow-line">═══▶</span>
    </div>

    <!-- COLUNA 2: a camada de sinal (propriedade) -->
    <div class="col signal-box pulse-glow">
      <div class="badge mono">{d.camada.posse}</div>
      <h3>{d.camada.titulo}</h3>
      {d.camada.linhas.map((l) => (
        <div class="srow">
          <strong>{l.t}</strong>
          <span class="mono">{l.s}</span>
        </div>
      ))}
    </div>

    <!-- fronteira de plataforma -->
    <div class="boundary" aria-hidden="true">
      <span class="blabel mono">{d.fronteira}</span>
    </div>

    <!-- COLUNA 3: plataformas (atual solida, futura tracejada) -->
    <div class="col platforms">
      <div class="plat current glass">
        <strong>{d.plataformaAtual.nome}</strong>
        <span class="mono">{d.plataformaAtual.nota}</span>
      </div>
      <div class="plat future">
        <strong>{d.plataformaFutura.nome}</strong>
        <span class="mono">{d.plataformaFutura.nota}</span>
      </div>
    </div>

    <!-- COLUNA 4: resultado -->
    <div class="col result mono">
      <span class="rcaret glow-line">▶</span>
      {d.resultado.map((r) => <div>{r}</div>)}
    </div>
  </div>
</section>

<style>
  .sig {
    margin-bottom: var(--section);
    margin-top: 60px; /* espacamento do Hero */
  }
  .intro {
    margin-bottom: 48px;
    max-width: 680px;
  }
  .intro h2 {
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 16px;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }
  .intro .lede {
    color: var(--ink-2);
    font-size: var(--fs-body);
    white-space: pre-line;
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .tese-box {
    padding: 20px 24px;
    border-left: 3px solid var(--signal);
  }
  .tese-label {
    display: block;
    color: var(--signal);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 8px;
  }
  .tese-box p {
    font-size: var(--fs-body);
    line-height: 1.6;
    font-weight: 500;
  }
  .eyebrow {
    margin-bottom: 20px;
    color: var(--accent);
    font-weight: 600;
  }
  .eyebrow-diagram {
    margin-bottom: 20px;
    color: var(--accent);
    font-weight: 600;
  }
  .grid {
    display: grid;
    grid-template-columns: auto auto 1fr auto auto auto;
    align-items: center;
    gap: 0 14px;
    padding: 32px 24px;
  }
  
  /* Glass Card base for grid */
  .glass {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    border-radius: 16px;
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  /* fontes */
  .src {
    font-size: var(--fs-small);
    color: var(--text-muted);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 10px 14px;
    background: rgba(0,0,0,0.2);
    white-space: nowrap;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .src:hover {
    transform: translateX(4px);
    border-color: var(--rebrand-primary-light);
  }
  .caret {
    color: var(--signal);
    margin-right: 8px;
    text-shadow: var(--glow-signal);
  }

  .conn {
    color: var(--accent);
    font-size: 13px;
  }
  .glow-line {
    text-shadow: 0 0 10px var(--accent);
  }

  /* camada de sinal: o elemento dominante */
  .signal-box {
    border: 1.5px solid var(--signal);
    background: rgba(200, 12, 153, 0.05);
    border-radius: 12px;
    padding: 20px 22px;
    gap: 4px;
    min-width: 240px;
    position: relative;
    overflow: hidden;
  }
  
  @keyframes pulseBorder {
    0% { box-shadow: 0 0 0 0 rgba(200, 12, 153, 0.4); }
    70% { box-shadow: 0 0 0 10px rgba(200, 12, 153, 0); }
    100% { box-shadow: 0 0 0 0 rgba(200, 12, 153, 0); }
  }
  .pulse-glow {
    animation: pulseBorder 3s infinite;
  }

  .badge {
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--signal);
    margin-bottom: 6px;
    text-shadow: var(--glow-signal);
  }
  .signal-box h3 {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .srow {
    display: flex;
    flex-direction: column;
    padding: 5px 0;
  }
  .srow strong {
    font-size: var(--fs-small);
    font-weight: 600;
  }
  .srow span {
    font-size: var(--fs-micro);
    color: var(--ink-2);
  }

  /* fronteira tracejada vertical */
  .boundary {
    position: relative;
    align-self: stretch;
    width: 1px;
    border-left: 1px dashed rgba(255, 255, 255, 0.2);
    margin: 0 12px;
  }
  .blabel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-90deg);
    transform-origin: center;
    white-space: nowrap;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    background: var(--paper);
    padding: 4px 8px;
    border-radius: 4px;
  }

  /* plataformas */
  .plat {
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 160px;
    border-radius: 12px;
  }
  .plat strong {
    font-size: var(--fs-small);
    font-weight: 600;
  }
  .plat span {
    font-size: 9.5px;
    color: var(--ink-2);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .current {
    /* Uses .glass class directly */
  }
  .future {
    border: 1px dashed rgba(255,255,255,0.15);
    color: var(--ink-2);
    background: rgba(0,0,0,0.1);
  }
  .future strong {
    color: var(--ink-2);
  }

  /* resultado */
  .result {
    font-family: var(--mono);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.5;
  }
  .rcaret {
    color: var(--signal);
    display: block;
    margin-bottom: 4px;
  }
  .result div:last-child {
    color: var(--ink-2);
  }

  /* mobile: empilha verticalmente, vira fluxo de cima p/ baixo */
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .conn,
    .boundary {
      display: none;
    }
    .signal-box {
      min-width: 0;
    }
    .platforms {
      flex-direction: row;
      gap: 10px;
    }
    .plat {
      flex: 1;
      min-width: 0;
    }
    .result {
      flex-direction: row;
      gap: 8px;
      align-items: baseline;
    }
    .rcaret {
      margin-bottom: 0;
    }
  }
</style>
