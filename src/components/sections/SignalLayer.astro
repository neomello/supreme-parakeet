---
import { diagrama as d } from "@data/proposta";
---

<section class="sig">
  <p class="eyebrow">// {d.label}</p>

  <div class="grid">
    <!-- COLUNA 1: fontes de trafego -->
    <div class="col sources">
      {d.fontes.map((f) => (
        <div class="src mono">
          <span class="caret">▸</span>{f}
        </div>
      ))}
    </div>

    <!-- conector -->
    <div class="conn" aria-hidden="true">
      <span class="mono">═══▶</span>
    </div>

    <!-- COLUNA 2: a camada de sinal (propriedade) -->
    <div class="col signal-box">
      <div class="badge mono">{d.camada.posse}</div>
      <h3>{d.camada.titulo}</h3>
      {d.camada.linhas.map((l) => (
        <div class="srow">
          <strong>{l.t}</strong>
          <span class="mono">{l.s}</span>
        </div>
      ))}
    </div>

    <!-- fronteira de plataforma -->
    <div class="boundary" aria-hidden="true">
      <span class="blabel mono">{d.fronteira}</span>
    </div>

    <!-- COLUNA 3: plataformas (atual solida, futura tracejada) -->
    <div class="col platforms">
      <div class="plat current">
        <strong>{d.plataformaAtual.nome}</strong>
        <span class="mono">{d.plataformaAtual.nota}</span>
      </div>
      <div class="plat future">
        <strong>{d.plataformaFutura.nome}</strong>
        <span class="mono">{d.plataformaFutura.nota}</span>
      </div>
    </div>

    <!-- COLUNA 4: resultado -->
    <div class="col result mono">
      <span class="rcaret">▶</span>
      {d.resultado.map((r) => <div>{r}</div>)}
    </div>
  </div>
</section>

<style>
  .sig {
    margin-bottom: var(--section);
  }
  .eyebrow {
    margin-bottom: 20px;
  }
  .grid {
    display: grid;
    grid-template-columns: auto auto 1fr auto auto auto;
    align-items: center;
    gap: 0 14px;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    padding: 26px 22px;
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* fontes */
  .src {
    font-size: var(--fs-small);
    color: var(--ink-2);
    border: 1px solid var(--rule);
    padding: 8px 12px;
    background: var(--paper);
    white-space: nowrap;
  }
  .caret {
    color: var(--signal);
    margin-right: 8px;
  }

  .conn {
    color: var(--ink-faint);
    font-size: 13px;
  }

  /* camada de sinal: o elemento dominante */
  .signal-box {
    border: 1.5px solid var(--signal);
    background: var(--signal-soft);
    padding: 16px 18px;
    gap: 4px;
    min-width: 240px;
  }
  .badge {
    font-size: var(--fs-micro);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--signal);
    margin-bottom: 6px;
  }
  .signal-box h3 {
    font-size: 15px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .srow {
    display: flex;
    flex-direction: column;
    padding: 5px 0;
  }
  .srow strong {
    font-size: var(--fs-small);
    font-weight: 600;
  }
  .srow span {
    font-size: var(--fs-micro);
    color: var(--ink-2);
  }

  /* fronteira tracejada vertical */
  .boundary {
    position: relative;
    align-self: stretch;
    width: 1px;
    border-left: 1px dashed var(--warn);
    margin: 0 8px;
  }
  .blabel {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-90deg);
    transform-origin: center;
    white-space: nowrap;
    font-size: 9px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--warn);
    background: var(--paper-2);
    padding: 0 6px;
  }

  /* plataformas */
  .plat {
    padding: 10px 14px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 150px;
  }
  .plat strong {
    font-size: var(--fs-small);
    font-weight: 600;
  }
  .plat span {
    font-size: 9.5px;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .current {
    border: 1px solid var(--rule);
    background: var(--paper);
  }
  .future {
    border: 1px dashed var(--rule);
    color: var(--ink-2);
  }
  .future strong {
    color: var(--ink-2);
  }

  /* resultado */
  .result {
    font-family: var(--mono);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.5;
  }
  .rcaret {
    color: var(--signal);
    display: block;
    margin-bottom: 4px;
  }
  .result div:last-child {
    color: var(--ink-faint);
  }

  /* mobile: empilha verticalmente, vira fluxo de cima p/ baixo */
  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .conn,
    .boundary {
      display: none;
    }
    .signal-box {
      min-width: 0;
    }
    .platforms {
      flex-direction: row;
      gap: 10px;
    }
    .plat {
      flex: 1;
      min-width: 0;
    }
    .result {
      flex-direction: row;
      gap: 8px;
      align-items: baseline;
    }
    .rcaret {
      margin-bottom: 0;
    }
  }
</style>
