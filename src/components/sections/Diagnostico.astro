---
import SectionHead from "@components/ui/SectionHead.astro";
import StatusDot from "@components/ui/StatusDot.astro";
import AuditorNote from "@components/ui/AuditorNote.astro";
import { diagnostico, diagnosticoNota, planoAuditoria } from "@data/proposta";
---

<section class="diag fade-in">
  <p class="eyebrow">▸ DIAGNÓSTICO EXTERNO — varredura pública / sem acesso interno</p>
  <SectionHead
    num="01"
    titulo="A estrutura pública é saudável. A operação parece empilhada."
    deck="A leitura externa indica uma operação em plataforma gerenciada, com boa camada de borda e sinais de maturidade técnica."
  />

  <div class="list glass fade-in">
    {diagnostico.map((d) => (
      <div class="row">
        <StatusDot status={d.status} />
        <span class="title">{d.titulo}</span>
        <span class="desc">{d.descricao}</span>
        <span class={`stat mono ${d.status}`}>{d.statusLabel}</span>
      </div>
    ))}
    <div class="note mono">
      <span class="info-icon">i</span>
      {diagnosticoNota}
    </div>

    <AuditorNote id="modal-auditoria" label="Plano de auditoria" title={planoAuditoria.titulo}>
      <ul class="audit-list">
        {planoAuditoria.itens.map((item) => (
          <li>
            <span class="bullet glow-line">▶</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </AuditorNote>
  </div>
</section>

<style>
  .diag {
    margin-bottom: var(--section);
  }
  .eyebrow {
    margin-bottom: 16px;
    color: var(--accent);
    font-weight: 600;
    font-size: var(--fs-small);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .list {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    border-radius: 16px;
    padding: 10px 24px;
  }
  .row {
    display: grid;
    grid-template-columns: 10px 190px 1fr 90px;
    gap: 18px;
    align-items: center;
    padding: 20px 0;
    border-bottom: var(--rule);
  }
  .row:last-child {
    border-bottom: none;
  }
  .title {
    font-weight: 600;
    font-size: var(--fs-small);
  }
  .bullet {
    color: var(--accent);
    font-size: 12px;
    margin-top: 2px;
  }
  .glow-line {
    text-shadow: 0 0 10px var(--accent);
  }
  .desc {
    color: var(--text-muted);
    font-size: var(--fs-small);
    line-height: 1.5;
  }
  .stat {
    font-size: var(--fs-micro);
    text-align: right;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .stat.ok {
    color: var(--signal);
  }
  .stat.watch {
    color: var(--warn);
  }
  .note {
    font-size: var(--fs-micro);
    color: var(--text-faint);
    margin-top: 16px;
  }
  @media (max-width: 720px) {
    .row {
      grid-template-columns: 10px 1fr;
      row-gap: 6px;
    }
    .desc,
    .stat {
      grid-column: 2;
    }
    .stat {
      text-align: left;
    }
  }

  /* List styles for the modal content */
  .audit-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .audit-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: var(--fs-body);
    line-height: 1.5;
    color: var(--text-muted);
  }
</style>
