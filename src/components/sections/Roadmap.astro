---
import SectionHead from "@components/ui/SectionHead.astro";
import { roadmap, roadmapIntro } from "@data/proposta";
---

<section class="roadmap">
  <SectionHead
    num="03"
    titulo={roadmapIntro.titulo}
    deck={roadmapIntro.deck}
  />

  <div class="timeline glass fade-in">
    {roadmap.map((item, index) => (
      <div class={`step ${item.fase}`}>
        <div class="track">
          <div class="dot"></div>
          {index < roadmap.length - 1 && <div class="line"></div>}
        </div>
        <div class="content">
          <div class="header">
            <span class="period mono">{item.periodo}</span>
            <span class={`badge mono ${item.fase}`}>{item.faseLabel}</span>
          </div>
          <h3>{item.titulo}</h3>
          <p>{item.descricao}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .roadmap {
    margin-bottom: var(--section);
  }
  .timeline {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    border-radius: 16px;
    padding: 32px 32px 12px;
  }
  
  .step {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 32px;
    margin-bottom: 24px;
    position: relative;
  }
  
  .track {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--rule);
    border: 2px solid transparent;
    z-index: 2;
    transition: all 0.3s ease;
  }
  
  .line {
    flex: 1;
    width: 1px;
    background: var(--rule);
    margin-top: 4px;
    min-height: 40px;
  }
  
  .step.ativo .dot {
    background: var(--signal);
    box-shadow: 0 0 12px rgba(200, 12, 153, 0.4);
  }
  .step.ativo .line {
    background: linear-gradient(to bottom, var(--signal), var(--rule));
  }
  
  .step.proximo .dot {
    background: var(--accent);
  }
  
  .content {
    padding-bottom: 32px;
  }
  
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  
  .period {
    color: var(--accent);
    font-size: var(--fs-small);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .badge {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 4px 8px;
    border-radius: 4px;
    border: 1px solid var(--rule);
    color: var(--text-muted);
  }
  
  .step.ativo .badge {
    border-color: var(--signal);
    color: var(--signal);
    background: rgba(200, 12, 153, 0.1);
  }
  
  .step.proximo .badge {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(10, 78, 228, 0.1);
  }
  
  h3 {
    font-size: var(--fs-body);
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 8px;
  }
  
  p {
    font-size: var(--fs-small);
    color: var(--text-muted);
    line-height: 1.5;
    max-width: 500px;
  }
</style>
