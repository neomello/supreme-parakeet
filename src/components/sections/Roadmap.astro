---
import SectionHead from "@components/ui/SectionHead.astro";
import { roadmap } from "@data/proposta";
---

<section class="rm">
  <SectionHead
    num="03"
    titulo="Para onde a operacao evolui em 24 meses"
    deck="Camadas seguintes, ativadas conforme a fundacao amadurece."
  />

  <div class="track">
    {roadmap.map((r) => (
      <div class={`node ${r.fase}`}>
        <div class="tick mono">{r.fase === "ativo" ? "◆" : "◇"}</div>
        <div class="m mono">{r.periodo}</div>
        <div class="t">{r.titulo}</div>
        <div class="d">{r.descricao}</div>
        <div class="s mono">{r.faseLabel}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .rm {
    margin-bottom: var(--section);
  }
  .track {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--rule);
  }
  .node {
    padding: 18px 18px 0 0;
    border-right: 1px solid var(--rule-soft);
  }
  .node:last-child {
    border-right: none;
  }
  .tick {
    font-size: 12px;
    color: var(--rule);
    margin-bottom: 10px;
  }
  .node.ativo .tick {
    color: var(--signal);
  }
  .m {
    font-size: 10px;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }
  .t {
    font-size: var(--fs-small);
    font-weight: 700;
    margin-bottom: 5px;
  }
  .d {
    font-size: var(--fs-micro);
    color: var(--ink-2);
    line-height: 1.5;
  }
  .s {
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ink-faint);
    margin-top: 12px;
  }
  .node.ativo .s {
    color: var(--signal);
  }
  @media (max-width: 720px) {
    .track {
      grid-template-columns: 1fr;
    }
    .node {
      border-right: none;
      border-bottom: 1px solid var(--rule-soft);
      padding: 18px 0;
    }
    .node:last-child {
      border-bottom: none;
    }
  }
</style>
