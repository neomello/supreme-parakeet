---
import AuditorNote from "@components/ui/AuditorNote.astro";
import SectionHead from "@components/ui/SectionHead.astro";
import { operacao, operacaoIntro } from "@data/proposta";
---

<section class="ops">
  <SectionHead
    num="02"
    titulo={operacaoIntro.titulo}
    deck={operacaoIntro.deck}
  />

  <div class="list glass fade-in">
    {operacao.map((o) => (
      <div class="op">
        <div class="n mono">{o.ordem}</div>
        <div class="body">
          <strong>{o.titulo}</strong>
          <span>{o.descricao}</span>
          {o.lista && (
            <ul class="sublist">
              {o.lista.map((item) => (
                <li><span class="bullet glow-line">▶</span> <span>{item}</span></li>
              ))}
            </ul>
          )}
          {o.dependeDe && (
            <span class="dep mono">└ depende de {o.dependeDe}</span>
          )}
        </div>
      </div>
    ))}
    
    <AuditorNote id="modal-operacao" label="Arquitetura de Venda" title="Detalhe do Escopo">
      <p class="nota-texto">{operacaoIntro.nota}</p>
    </AuditorNote>
  </div>
</section>

<style>
  .ops {
    margin-bottom: var(--section);
  }
  .list {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    -webkit-backdrop-filter: var(--glass-blur);
    backdrop-filter: var(--glass-blur);
    box-shadow: var(--glass-shadow);
    border-radius: 16px;
    padding: 10px 24px;
  }
  .op {
    display: grid;
    grid-template-columns: 52px 1fr;
    gap: 20px;
    padding: 24px 0;
    border-bottom: 1px solid var(--rule);
  }
  .op:first-child {
    padding-top: 14px;
  }
  .op:last-child {
    border-bottom: none;
    padding-bottom: 14px;
  }
  .n {
    font-size: 24px;
    font-weight: 600;
    color: var(--text-faint);
  }
  .body strong {
    display: block;
    font-size: var(--fs-body);
    font-weight: 600;
    margin-bottom: 5px;
  }
  .body > span {
    display: block;
    color: var(--text-muted);
    font-size: var(--fs-small);
    line-height: 1.55;
    max-width: 560px;
  }
  .dep {
    font-size: var(--fs-micro);
    color: var(--text-faint);
    margin-top: 10px;
  }
  .sublist {
    list-style: none;
    padding: 0;
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
  }
  .sublist li {
    font-size: 13px;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .bullet {
    font-size: 9px;
    color: var(--accent);
  }
  .nota-texto {
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-main);
  }
</style>
