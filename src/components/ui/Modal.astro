---
interface Props {
  id: string;
}
const { id } = Astro.props;
---

<dialog id={id} class="glass-modal">
  <div class="modal-inner">
    <button class="close-btn" aria-label="Fechar" onclick={`document.getElementById('${id}').close()`}>&times;</button>
    <slot />
  </div>
</dialog>

<style>
  .close-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    background: transparent;
    border: none;
    color: var(--ink-2);
    font-size: 24px;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s ease;
    padding: 4px;
    z-index: 10;
  }
  .close-btn:hover {
    color: var(--ink);
  }
  .modal-inner {
    padding: 32px 32px;
    position: relative;
  }
</style>
