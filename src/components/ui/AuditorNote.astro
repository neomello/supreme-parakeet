---
interface Props {
  id: string;
  label: string;
  title: string;
}
const { id, label, title } = Astro.props;
---

<div class="auditor-action fade-in">
  <button class="auditor-trigger" onclick={`document.getElementById('${id}').classList.add('active')`}>
    <div class="auditor-photo"></div>
    <div class="auditor-info">
      <span class="mono">NEØ // OPERAÇÃO</span>
      <strong>{label}</strong>
    </div>
  </button>
</div>

<div id={id} class="modal-overlay" onclick={`if(event.target.id === '${id}') this.classList.remove('active')`}>
  <div class="modal-content glass">
    <div class="modal-header">
      <div class="auditor-photo"></div>
      <div class="modal-title">
        <span class="mono">NEØ // NOTA OPERACIONAL</span>
        <h3>{title}</h3>
      </div>
      <button class="close-modal" onclick={`document.getElementById('${id}').classList.remove('active')`}>×</button>
    </div>
    <div class="modal-body">
      <slot />
    </div>
  </div>
</div>

<style>
  /* Acao do Auditor */
  .auditor-action {
    margin-top: 32px;
    display: flex;
    justify-content: flex-end;
  }
  .auditor-trigger {
    display: flex;
    align-items: center;
    gap: 12px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-align: left;
    padding: 8px;
    border-radius: 40px;
    transition: all 0.3s ease;
  }
  .auditor-trigger:hover {
    background: rgba(255, 255, 255, 0.05);
  }
  .auditor-photo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-image: url('https://github.com/nettomello.png');
    background-size: cover;
    background-position: center;
    border: 2px solid var(--signal);
    box-shadow: 0 0 15px rgba(200, 12, 153, 0.3);
  }
  .auditor-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .auditor-info span {
    font-size: 9px;
    color: var(--signal);
    letter-spacing: 0.1em;
  }
  .auditor-info strong {
    font-size: 13px;
    color: var(--text-main);
    font-weight: 600;
  }

  /* MODAL */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(4, 14, 36, 0.8);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 999;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
  }
  .modal-content {
    background: var(--blue); /* Fallback */
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    padding: 32px;
    border-radius: 16px;
    width: 90%;
    max-width: 500px;
    transform: translateY(20px);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 24px 60px rgba(0,0,0,0.4);
    color: var(--text-main);
  }
  .modal-overlay.active .modal-content {
    transform: translateY(0);
  }
  .modal-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    position: relative;
  }
  .modal-title {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .modal-title span {
    font-size: 10px;
    color: var(--signal);
    letter-spacing: 0.1em;
  }
  .modal-title h3 {
    font-size: 18px;
    font-weight: 600;
  }
  .close-modal {
    position: absolute;
    top: 0;
    right: 0;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 24px;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s ease;
  }
  .close-modal:hover {
    color: var(--signal);
  }
  .modal-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-muted);
  }
</style>
